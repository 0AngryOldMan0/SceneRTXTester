{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Debug, platform backend)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        ".",
        "-B",
        "build",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DUSE_METAL_RENDERER=ON",
        "-DUSE_HIP_RENDERER=OFF",
        "-DUSE_CUDA_RENDERER=OFF"
      ],
      "windows": {
        "command": "cmake",
        "args": [
          "-S",
          ".",
          "-B",
          "build",
          "-DCMAKE_BUILD_TYPE=Debug",
          "-DUSE_HIP_RENDERER=ON",
          "-DUSE_CUDA_RENDERER=OFF",
          "-DUSE_METAL_RENDERER=OFF",
          "-DCMAKE_PREFIX_PATH=${env:HIP_PATH}",
          "-DCMAKE_HIP_ARCHITECTURES=gfx1030"
        ]
      },
      "osx": {
        "command": "cmake",
        "args": [
          "-S",
          ".",
          "-B",
          "build",
          "-DCMAKE_BUILD_TYPE=Debug",
          "-DUSE_METAL_RENDERER=ON",
          "-DUSE_HIP_RENDERER=OFF",
          "-DUSE_CUDA_RENDERER=OFF"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build (cmake --build build)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build"
      ],
      "dependsOn": [
        "Configure (Debug, platform backend)"
      ],
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Clean + Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-E",
        "rm",
        "-rf",
        "build"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "if (Test-Path build) { Remove-Item -Recurse -Force build }"
        ]
      },
      "dependsOn": [
        "Build (cmake --build build)"
      ],
      "dependsOrder": "sequence",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run SceneRTXTester (integrated terminal)",
      "type": "shell",
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "\"${workspaceFolder}/build/SceneRTXTester\" \"${input:scenePath}\" ${input:renderType} ${input:resolutionArgs}"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "& \"${workspaceFolder}\\build\\SceneRTXTester.exe\" \"${input:scenePath}\" ${input:renderType} ${input:resolutionArgs}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "Build (cmake --build build)"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      }
    },
    {
      "label": "Run SceneRTXTester (preview)",
      "type": "shell",
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "\"${workspaceFolder}/build/SceneRTXTester\" \"${input:scenePath}\" -preview ${input:resolutionArgs}"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "& \"${workspaceFolder}\\build\\SceneRTXTester.exe\" \"${input:scenePath}\" -preview ${input:resolutionArgs}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "Build (cmake --build build)"
      ],
      "dependsOrder": "sequence",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      }
    },
    {
      "label": "Run SceneRTXTester (progressive)",
      "type": "shell",
      "command": "/bin/zsh",
      "args": [
        "-lc",
        "\"${workspaceFolder}/build/SceneRTXTester\" \"${input:scenePath}\" -progressive ${input:resolutionArgs}"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "& \"${workspaceFolder}\\build\\SceneRTXTester.exe\" \"${input:scenePath}\" -progressive ${input:resolutionArgs}"
        ]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "Build (cmake --build build)"
      ],
      "dependsOrder": "sequence",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      }
    }
  ],
  "inputs": [
    {
      "id": "scenePath",
      "type": "promptString",
      "description": "Scene file path (relative or absolute)",
      "default": "Scene/UE5/SubwayTunnel/scene.json"
    },
    {
      "id": "renderType",
      "type": "pickString",
      "description": "Render type",
      "options": [
        "-preview",
        "-progressive",
        "-textureDebug"
      ],
      "default": "-preview"
    },
    {
      "id": "resolutionArgs",
      "type": "promptString",
      "description": "Resolution/spp (optional): '1920 1080' or '1920 1080 10'",
      "default": ""
    }
  ]
}
